# Runtime
FLASK_ENV=development
APP_LOCALE=en-US

# Data
APP_DB_PATH=data/studio.db

# AI provider selection: mock | openai | azure_openai | ollama
AI_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
